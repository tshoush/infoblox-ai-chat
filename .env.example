# Infoblox Configuration (required)
INFOBLOX_GRID_IP=192.168.1.1
INFOBLOX_ADMIN_USER=admin
INFOBLOX_ADMIN_PASS=infoblox
INFOBLOX_NETWORK_VIEW=default
INFOBLOX_WAPI_VERSION=2.12.3
INFOBLOX_VERIFY_SSL=false
INFOBLOX_CONNECTION_TIMEOUT=30
INFOBLOX_MAX_RETRIES=3

# LLM Configuration (required)
# Supported providers: openai, claude (alias: anthropic), grok (alias: xai), ollama, unsloth
# This sets the DEFAULT; you can switch providers/keys at runtime in the UI (⚙)
# or via POST /api/providers (persisted to backend/providers.local.json).
LLM_PROVIDER=claude
LLM_API_KEY=your_api_key_here
LLM_MODEL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_TIMEOUT=30
LLM_FALLBACK_ENABLED=true

# For a local Ollama provider, set:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3

# Redis Configuration (optional; cache is disabled if unset)
# REDIS_URL=redis://localhost:6379/0

# RAG embeddings (optional; requires an OpenAI key, RAG is disabled without it)
# OPENAI_API_KEY=sk-...

# Team chatbots (optional). All share IACI_API_URL and RBAC is fail-closed
# (no *_WRITER_USERS = answers only, all changes refused).
# IACI_API_URL=http://localhost:5050

# Change-management: require a Jira/ServiceNow ticket reference in any write
# request before it can be approved (applies to all bots). Off by default.
# IACI_REQUIRE_CHANGE_TICKET=true
# IACI_TICKET_PATTERN=\b(?:[A-Z][A-Z0-9]{1,9}-\d+|(?:CHG|INC|RITM|CTASK)\d{4,})\b

# Slack (./setup.sh slack) — integrations/slack/README.md
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_WRITER_USERS=U0123,U0456     # Slack user IDs allowed to approve changes
# SLACK_ADMIN_USERS=U0123            # may also approve DELETEs (destructive)
# SLACK_AUDIT_CHANNEL=C0AUDIT        # optional channel to mirror executions

# Microsoft Teams (./setup.sh teams) — integrations/teams/README.md
# MicrosoftAppId=...
# MicrosoftAppPassword=...
# TEAMS_WRITER_USERS=29:1abc...
# TEAMS_ADMIN_USERS=29:1abc...

# WhatsApp Cloud API (./setup.sh whatsapp) — integrations/whatsapp/README.md
# WHATSAPP_TOKEN=EAAG...
# WHATSAPP_PHONE_NUMBER_ID=10987654321
# WHATSAPP_VERIFY_TOKEN=some-secret-string
# WHATSAPP_WRITER_USERS=15551234567  # phone numbers (wa_id)
# WHATSAPP_ADMIN_USERS=15551234567

# Backend hardening (optional, recommended for shared/production deploys)
# IACI_API_KEY=change-me                 # require this key on /api/* and /v1/* (X-API-Key or Bearer)
# IACI_CORS_ORIGINS=http://localhost:3300 # comma-separated allowlist (default "*")
# IACI_REQUIRE_SECOND_APPROVER=true       # four-eyes: approver must differ from requester (bots)
# WHATSAPP_APP_SECRET=...                  # verifies Meta webhook signatures (required if WhatsApp writers set)

# Development Settings
FLASK_DEBUG=0
NODE_ENV=development

# Infoblox Configuration
INFOBLOX_GRID_IP=192.168.1.1
INFOBLOX_ADMIN_USER=admin
INFOBLOX_ADMIN_PASS=infoblox

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=

# Optional: For local LLM providers
# LLM_PROVIDER=local
# LLM_BASE_URL=http://localhost:11434

# Redis Configuration (optional, defaults to docker service)
# REDIS_URL=redis://localhost:6379/0

# Development Settings
FLASK_ENV=development
FLASK_DEBUG=1
NODE_ENV=development